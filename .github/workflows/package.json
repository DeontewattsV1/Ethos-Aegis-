name: docs

on:
  push:
    paths:
      - "src/**"
      - "examples/**"
      - "scripts/**"
      - "README.md"
      - ".github/workflows/docs.yml"
  pull_request:
    branches: [main]
    paths:
      - "src/**"
      - "examples/**"
      - "scripts/**"
      - "README.md"
  workflow_dispatch:

concurrency:
  group: docs-${{ github.ref }}
  cancel-in-progress: true

permissions:
  contents: write
  pull-requests: write

jobs:
  regenerate:
    runs-on: ubuntu-latest
    # ─── Infinite-loop safeguard ────────────────────────────────────────────────
    # The job below pushes back to `main` using `secrets.GITHUB_TOKEN`. There
    # are two independent safeguards keeping that push from re-triggering this
    # workflow into an infinite loop. **Either one alone is sufficient — both
    # together are defense-in-depth.**
    #
    # 1. GitHub's built-in protection: workflow runs triggered by pushes that
    #    use `secrets.GITHUB_TOKEN` do NOT create new workflow runs. This is
    #    a documented platform behavior, not something we configure.
    #    https://docs.github.com/en/actions/security-for-github-actions/security-guides/automatic-token-authentication#using-the-github_token-in-a-workflow
    #
    # 2. The `contains()` guard below: even if the commit-back ever switched
    #    to a PAT (which DOES re-trigger workflows), this job would still skip
    #    itself because the bot commit's message contains the literal
    #    sentinel "docs refresh README snippets".
    #
    # Verified live by inspecting the last 5 bot commits on `main` — none
    # triggered a new docs.yml run (see PR-D in the session history).
    if: "${{ !contains(github.event.head_commit.message, 'docs refresh README snippets') }}"
    steps:
      - uses: actions/checkout@v4
        with:
          fetch-depth: 0
          token: ${{ secrets.GITHUB_TOKEN }}

      - uses: actions/setup-node@v4
        with:
          node-version: "20"
          cache: "npm"

      - run: npm ci

      - name: Sync README snippets
        run: npx tsx scripts/sync-readme.ts

      - name: Run examples and capture output
        run: npx tsx scripts/run-examples.ts

      # The second sync pass injects fresh output blocks and (only on main) a
      # refreshed last-verified timestamp. We deliberately skip the timestamp
      # bump on PR runs so PRs don't fail purely because the timestamp moved —
      # PRs should only fail when the underlying example/snapshot content drifts.
      - name: Re-sync README (PR — no timestamp bump)
        if: github.event_name == 'pull_request'
        run: npx tsx scripts/sync-readme.ts

      - name: Re-sync README (main — refresh last-verified stamp)
        if: github.event_name == 'push' && github.ref == 'refs/heads/main'
        env:
          LDT_FORCE_STAMP: "1"
        run: npx tsx scripts/sync-readme.ts

      - name: Re-sync README (feature branch push or manual dispatch)
        if: (github.event_name == 'push' && github.ref != 'refs/heads/main') || github.event_name == 'workflow_dispatch'
        run: npx tsx scripts/sync-readme.ts

      - name: Detect changes
        id: diff
        run: |
          if git diff --quiet; then
            echo "changed=false" >> "$GITHUB_OUTPUT"
          else
            echo "changed=true" >> "$GITHUB_OUTPUT"
          fi

      - name: Commit back to main
        if: steps.diff.outputs.changed == 'true' && github.event_name == 'push' && github.ref == 'refs/heads/main'
        run: |
          git config user.name "github-actions[bot]"
          git config user.email "41898282+github-actions[bot]@users.noreply.github.com"
          git add README.md docs/output-snapshots
          # IMPORTANT: the first line of this commit message MUST stay
          # "docs refresh README snippets ..." — the `startsWith()` guard at
          # the top of this workflow keys off that exact prefix.
          git commit -m "docs refresh README snippets + output snapshots"
          git push

      - name: Fail PR if drift detected
        if: steps.diff.outputs.changed == 'true' && github.event_name == 'pull_request'
        run: |
          {
            echo "::error::README / snapshot drift detected on this branch."
            echo "::error::Run 'npm run docs' locally and commit the result."
          } >&2
          git --no-pager diff --stat
          exit 1
