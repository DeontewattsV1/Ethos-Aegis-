{
  "name": "living-docs-template",
  "version": "0.1.1",
  "description": "Self-demonstrating, always-current documentation template. Source code, examples, and README are kept in sync by CI.",
  "license": "Apache-2.0",
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "main": "src/index.ts",
  "files": [
    "src",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "test": "vitest run --coverage",
    "test:watch": "vitest",
    "docs": "tsx scripts/sync-readme.ts && tsx scripts/run-examples.ts && tsx scripts/sync-readme.ts",
    "docs:api": "typedoc --out docs/api src/index.ts",
    "verify": "tsx scripts/run-examples.ts && tsx scripts/validate-docs.ts",
    "repl": "tsx repl.ts",
    "examples:run": "tsx scripts/run-examples.ts",
    "lint": "tsc --noEmit",
    "build": "tsc -p tsconfig.build.json",
    "ci": "npm ci && npm run lint && npm test && npm run verify && npm run build",
    "upgrade": "tsx scripts/upgrade.ts",
    "upgrade:dry": "tsx scripts/upgrade.ts --dry-run"
  },
  "devDependencies": {
    "@types/node": "^20.19.41",
    "@vitest/coverage-v8": "^4.1.7",
    "tsx": "^4.22.3",
    "typedoc": "^0.26.11",
    "typescript": "^5.6.3",
    "vitest": "^4.1.7"
  },
  "keywords": [
    "living-docs",
    "documentation",
    "typescript",
    "observable",
    "event-emitter"
  ]
}
